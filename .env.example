PORT=3000
NODE_ENV=development

# Conexão principal: URL completa (MySQL/MariaDB ou PostgreSQL)
# MySQL/MariaDB — exemplo (ajuste host, porta, usuário, senha e base):
# DATABASE_URL=mysql://usuario:senha@127.0.0.1:3306/nome_do_banco
#
# Se a senha tiver caracteres especiais (@, :, /, #, etc.), use percent-encoding na URL.
DATABASE_URL=

# MySQL: TLS (obrigatório se o servidor tiver require_secure_transport=ON).
# Com host remoto (IP ou domínio com ponto) na URL, o TLS liga automaticamente.
# DATABASE_SSL=false
# DATABASE_SSL=true
# Se o certificado não for reconhecido pela CA do sistema:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Sem DATABASE_URL: MySQL por padrão (use DB_DRIVER=postgres para PostgreSQL + variáveis abaixo)
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=default

# Schema: aplique com `npm run migration:run` (CLI TypeORM). Por defeito NÃO use synchronize —
# se não, o TypeORM altera o schema ao arrancar a API e as migrations passam a falhar (objeto já existe / coluna já removida).
# Só para protótipo rápido sem migrations: DB_SYNCHRONIZE=true
# DB_SYNCHRONIZE=false

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# SMS (Comtele) — login por celular: POST /auth/sms/request e POST /auth/sms/verify
# Em desenvolvimento, sem COMTELE_AUTH_KEY o código é só registado em log (consola).
# Chave em https://sms.comtele.com.br (área do programador). Erros 401 = chave errada ou conta desativada;
# 400 com texto sobre créditos = saldo insuficiente; COMTELE_SENDER_ID deve existir na sua conta Comtele.
# COMTELE_API_BASE_URL=https://sms.comtele.com.br
# COMTELE_AUTH_KEY=
# COMTELE_SENDER_ID=66912

# Consulta de CEP (hub Tagsa — mesma API que tickets-api GET /addresses/zip/:zip)
# BUSCA_CEP_KEY=

# URL base mostrada no Swagger (opcional; por omissão usa http://localhost:PORT)
# SWAGGER_SERVER_URL=https://api.exemplo.com

# URL base do frontend (condo-web). Links de convite no e-mail e no painel:
# {FRONTEND_PUBLIC_URL}/invitations/{token} → redireciona para o cadastro com o token.
# Obrigatório para criar/enviar convites.
# FRONTEND_PUBLIC_URL=http://localhost:4200

# Armazenamento de comprovantes (transações)
# local = pasta STORAGE_PATH no servidor da API (padrão)
# nextcloud = WebDAV no teu Nextcloud (ex.: https://storage.meucondominio.cloud)
# STORAGE_DRIVER=local
# STORAGE_PATH=storage
#
# Com STORAGE_DRIVER=nextcloud — use utilizador dedicado + palavra-passe de aplicação
# (Definições → Segurança → Palavras-passe de aplicação). NÃO use a senha MariaDB do stack.
# NEXTCLOUD_URL=https://storage.meucondominio.cloud
# NEXTCLOUD_USERNAME=condo_api
# NEXTCLOUD_APP_PASSWORD=
# Pasta sob "Ficheiros" desse utilizador (criada automaticamente por MKCOL se possível):
# NEXTCLOUD_RECEIPTS_PATH=condo-receipts

# SMTP opcional (sem SMTP_HOST, convites / reset de senha só em log na consola).
# Valores reais ficam só no teu .env local — não commite esse ficheiro.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# Remetente visível nos e-mails (pode ser o mesmo que SMTP_USER):
# EMAIL_FROM=noreply@exemplo.com

# Painel de plataforma (condo-adm): e-mails (minúsculos) promovidos a platform_admin no arranque, separados por vírgula.
# PLATFORM_ADMIN_EMAILS=admin@exemplo.com

# Asaas (faturação SaaS) — nunca commite chaves reais no repositório.
# ASAAS_ENV=sandbox
# Produção (ASAAS_ENV=production) — host da API, sem /v3:
# ASAAS_API_KEY=
# ASAAS_URL=https://api.asaas.com
# Sandbox (omissão ou ASAAS_ENV=sandbox):
# ASAAS_API_KEY_SANDBOX=
# ASAAS_URL_SANDBOX=https://api-sandbox.asaas.com
# Obrigatório em contas novas (Asaas): nome da app no User-Agent
# ASAAS_USER_AGENT=condo-api
# Webhook (opcional; validação do token no header):
# ASAAS_WEBHOOK_ACCESS_TOKEN=
#
# Sincronização reversa (quando webhook falha): POST /platform/billing/asaas/sync-pending
# Cron opcional a cada 2h — consulta pagamentos pendentes na API Asaas:
# ASAAS_PENDING_SYNC_CRON_ENABLED=true

# Ciclo diário de mensalidade SaaS (vencimento no dia de entrada do condomínio; geração ~10 dias antes; suspensão 5 dias após vencimento sem pagamento):
# SAAS_BILLING_DAILY_CRON_ENABLED=true
# Fuso para datas do ciclo (calendário de geração / vencimento):
# SAAS_BILLING_TZ=America/Sao_Paulo
# Dias antes do vencimento para gerar cobrança e enviar e-mail:
# SAAS_BILLING_GENERATE_DAYS_BEFORE=10
# Dias após o vencimento para marcar faturação como suspensa se a cobrança continuar pendente/atrasada:
# SAAS_BILLING_SUSPEND_DAYS_AFTER_DUE=5

# Planos SaaS: saas_plans (preço por unidade). is_default=true → novos utilizadores.
# Mudar o padrão: POST /platform/plans/:id/set-default (painel admin ou Swagger).
