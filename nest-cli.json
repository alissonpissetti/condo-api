{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "outDir": "build",
    "assets": [
      {
        "include": "assets/**/*",
        "outDir": "build",
        "watchAssets": true
      }
    ]
  }
}

